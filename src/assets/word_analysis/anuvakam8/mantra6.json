  "commentaries": {
    "sayana": {
      "rishi": "Nārada",
      "chandas": "Anuṣṭup",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "It means he who kills an opponent without effort, whether that opponent is in front or far away. In the world also, whoever kills an opponent, he (the God) alone is the killer in that form. Therefore, the Lord said to Arjuna:\n\"These have already been slain by me; be you a mere instrument, O left-handed archer (Savyasachin).\"\n'Haniyan' is the excessive killer of all at the time of destruction (samhara). (6)"
    },
    "bhatta_bhaskara": {
      "rishi": "Nārada",
      "chandas": "Anuṣṭup",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "'Namah hantre cha'—to the self of whoever indeed kills; the idea is that every killer kills through your power. 'Haniyase cha'—to the excessive killer. [Grammatical note]. One whose power exceeds all, by which you alone deserve to be the Lord of beings (Pashupati). (6)"
    },
    "abhinava_shankara": {
