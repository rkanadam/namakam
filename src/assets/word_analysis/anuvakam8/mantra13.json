  "commentaries": {
    "sayana": {
      "rishi": "Nārada",
      "chandas": "Anuṣṭup",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "'Paryah'—he who exists on the far shore (para-tire) of the ocean of worldly existence (Samsara), as the object of meditation for those seeking liberation. 'Avaryah'—he who exists on the near shore (avara-tire), in the midst of Samsara, as the granter of desired fruits. (13)"
    },
    "bhatta_bhaskara": {
      "rishi": "Nārada",
      "chandas": "Anuṣṭup",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "'Namah paryaya cha'—to him existing on the far shore (para-tire) of rivers etc. [Grammatical note]. 'Avaryaya cha'—to him existing on the near shore (avara-tire). Someone says: \"Tirthas and the like are with respect to Samsara.\" Tirthas are the holy assemblies (samavayas) like the Shaivas etc.; he exists in those. Staying there, he graces the world. To him existing on the banks, during times (of transition) etc. The far shore (para) is pure; the near shore (avara) is impure. (13)"
    },
    "abhinava_shankara": {
