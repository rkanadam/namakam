  "commentaries": {
    "sayana": {
      "rishi": "Atreya",
      "chandas": "Mahāvirāṭ",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "'Vatyah'—one seen along with the wind (vata). 'Reshma' is the time of dissolution (pralaya) where beings perish (rishyanti); he who exists there in the form of a specific type of rainwater mixed with gravel, stones, etc., is 'reshmiyah'. (15)"
    },
    "bhatta_bhaskara": {
      "rishi": "Atreya",
      "chandas": "Mahāvirāṭ",
      "devata": "Śambhu",
      "sanskrit": "",
      "english": "'Namah vatyaya cha'—to him existing in rains produced by the wind. 'Reshmiyaya cha'—'reshma' is the end of an age (yuganta) when a wind named Samvarta blows, raining stones and gravel; that is 'reshma'. Some say it refers to the summer season. Others say 'reshma' are the dust clouds raised by the wind. To him existing there. [Grammatical note]. (15)"
    },
